# Whisper — CPU sunucu için faster-whisper
WHISPER_MODEL=large-v3-turbo

# Görüntü analizi — CPU'da çalışmaz, kapalı (GPU gelince true yap)
IMAGE_ANALYSIS_ENABLED=false

# Ollama — yerel LLM (veri dışarı çıkmaz)
OLLAMA_MODEL=nous-hermes2
OLLAMA_URL=http://localhost:11434

# Sunucu
PORT=5050

# Hastane Bilgileri (PDF başlığında görünür)
HOSPITAL_NAME=Bursa Uludağ Üniversitesi Hastanesi
HOSPITAL_DEPT=Radyoloji Anabilim Dalı
